# Copy this file to .env and fill in your values

# Anthropic API key — get one at https://console.anthropic.com
# If omitted, the app runs in mock mode with static demo components
ANTHROPIC_API_KEY=

# JWT secret for session signing — use any long random string in production
JWT_SECRET=development-secret-key

# Prisma database URL — SQLite for local dev
DATABASE_URL="file:./prisma/dev.db"
